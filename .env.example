# Keep false to run app in mock mode (default).
# Set true when you are ready to use Supabase auth.
VITE_ENABLE_SUPABASE_AUTH=false

# Supabase project settings
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: explicit app URL used for auth redirect links in emails.
# If omitted, the app will use the current browser origin.
VITE_APP_URL=http://localhost:8080
